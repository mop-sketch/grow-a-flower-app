{
  "name": "grow-a-flower",
  "version": "1.0.0",
  "description": "Grow a Flower - offline Android game (Capacitor)",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "node scripts/copy-web.mjs",
    "sync": "npm run build:web && cap sync",
