    "android": "npm run build:web && cap sync android && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/network": "^6.0.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
